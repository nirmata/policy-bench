# Copy to nctl.env / claude.env / cursor.env and fill in values.
# These files are .gitignored — never commit real keys.

# --- nctl.env ---
# NIRMATA_TOKEN=your-nirmata-api-token
# NIRMATA_URL=https://nirmata.io
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...
# AWS_REGION=us-west-2

# --- claude.env ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- cursor.env ---
# CURSOR_API_KEY=your-cursor-api-key

# --- codex.env ---
# CODEX_API_KEY=sk-...
