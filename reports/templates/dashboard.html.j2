<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Policy as Code Benchmark — Nirmata</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&family=Ubuntu:wght@500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #020e1d; --fg: #D3DEF4; --card: #132448; --border: #1e345d;
    --accent: #71CFEB; --green: #459666; --red: #FF262A; --yellow: #F3782C;
    --muted: #A7B0BA; --orange: #F3782C; --cyan: #71CFEB;
    --blue: #2E5596; --light-bg: #F3F6FB;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Open Sans', -apple-system, BlinkMacSystemFont, sans-serif;
         background: var(--bg); color: var(--fg); padding: 2rem 3rem; max-width: 1200px; margin: 0 auto; }

  /* Header / Branding */
  .header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem; }
  .nirmata-logo { height: 40px; }
  .nirmata-logo svg { height: 40px; width: auto; }
  h1 { font-family: 'Ubuntu', sans-serif; font-size: 1.5rem; font-weight: 700; margin-bottom: 0.15rem; color: #FFFFFF; }
  h2 { font-family: 'Ubuntu', sans-serif; }
  .subtitle { color: var(--muted); font-size: 0.82rem; margin-bottom: 2.5rem; }

  /* Leaderboard */
  .leaderboard { background: var(--card); border: 1px solid var(--border); border-radius: 12px;
                 padding: 2rem; margin-bottom: 2rem; }
  .leaderboard h2 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em;
                     color: var(--muted); margin-bottom: 1.25rem; }
  .lb-table { width: 100%; border-collapse: collapse; }
  .lb-table th { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em;
                 color: var(--muted); font-weight: 600; padding: 0 0.75rem 0.75rem; text-align: left; }
  .lb-table td { padding: 0.85rem 0.75rem; border-top: 1px solid var(--border); }
  .lb-table tr:first-child td { border-top: none; }
  .tool-name { font-family: 'Ubuntu', sans-serif; font-weight: 700; font-size: 1rem; }
  .pass-rate { font-family: 'Ubuntu', sans-serif; font-size: 1.8rem; font-weight: 700; }
  .pass-rate.high { color: var(--green); }
  .pass-rate.mid { color: var(--orange); }
  .pass-rate.low { color: var(--red); }
  .metric { font-size: 0.9rem; color: var(--fg); }
  .metric-label { font-size: 0.7rem; color: var(--muted); }
  .rank { display: inline-flex; align-items: center; justify-content: center;
          width: 30px; height: 30px; border-radius: 50%; font-weight: 800; font-size: 0.9rem; }
  .rank-1 { background: linear-gradient(135deg, #F3782C, #ff9a56); color: #fff; }
  .rank-2 { background: linear-gradient(135deg, #71CFEB, #335D84); color: #fff; }
  .rank-3 { background: linear-gradient(135deg, #2E5596, #4e749d); color: #fff; }
  .rank-n { background: var(--border); color: var(--fg); }

  /* Charts grid */
  .charts { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem; }
  .chart-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; }
  .chart-card h2 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em;
                    color: var(--muted); margin-bottom: 1rem; }
  canvas { max-height: 280px; cursor: pointer; }

  /* Results table */
  .results { background: var(--card); border: 1px solid var(--border); border-radius: 12px;
             padding: 2rem; }
  .results h2 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em;
                color: var(--muted); margin-bottom: 1.25rem; }
  .table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .res-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .res-table th { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em;
                  color: var(--muted); font-weight: 600; padding: 0 0.6rem 0.6rem; text-align: left;
                  white-space: nowrap; }
  .res-table td { padding: 0.55rem 0.6rem; border-top: 1px solid var(--border); }
  .pass { color: #ABEFC6; font-weight: 600; }
  .fail { color: #ff797a; font-weight: 600; }
  .clickable { cursor: pointer; transition: background 0.15s; border-radius: 4px; }
  .clickable:hover { background: rgba(113, 207, 235, 0.1); }
  .err-text { font-size: 0.72rem; color: var(--muted); max-width: 350px;
              overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  /* About section */
  .about { background: var(--card); border: 1px solid var(--border); border-radius: 12px;
           padding: 1.5rem 2rem; margin-bottom: 2rem; line-height: 1.6; font-size: 0.88rem; color: var(--fg); }
  .about p { margin-bottom: 0.75rem; }
  .about p:last-child { margin-bottom: 0; }
  .about a { color: var(--accent); text-decoration: none; }
  .about a:hover { text-decoration: underline; }

  /* Footer */
  .footer { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--border);
            text-align: center; color: var(--muted); font-size: 0.75rem; }
  .footer a { color: var(--accent); text-decoration: none; }
  .footer a:hover { text-decoration: underline; }

  /* ---- Modal ---- */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(2,14,29,0.85);
                   z-index: 1000; justify-content: center; align-items: flex-start;
                   padding: 3vh 1rem; overflow-y: auto; }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--card); border: 1px solid var(--border); border-radius: 12px;
           width: 100%; max-width: 780px; margin: 0 auto; overflow: hidden;
           animation: slideUp 0.2s ease-out; }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .modal-header { display: flex; align-items: center; justify-content: space-between;
                  padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border); }
  .modal-header h3 { font-family: 'Ubuntu', sans-serif; font-size: 1rem; font-weight: 700; color: #fff; }
  .modal-badge { display: inline-block; padding: 0.2rem 0.7rem; border-radius: 100px;
                 font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; }
  .modal-badge.pass-badge { background: rgba(69,150,102,0.2); color: #ABEFC6; }
  .modal-badge.fail-badge { background: rgba(255,38,42,0.15); color: #ff797a; }
  .modal-close { background: none; border: none; color: var(--muted); font-size: 1.5rem;
                 cursor: pointer; padding: 0 0.25rem; line-height: 1; }
  .modal-close:hover { color: #fff; }
  .modal-body { padding: 1.5rem; }

  /* Metrics bar */
  .metrics-bar { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem; }
  .metric-chip { background: rgba(30,52,93,0.6); border-radius: 8px; padding: 0.5rem 0.85rem; }
  .metric-chip .mc-label { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em;
                           color: var(--muted); display: block; margin-bottom: 0.15rem; }
  .metric-chip .mc-value { font-family: 'Ubuntu', sans-serif; font-size: 0.95rem; font-weight: 700; color: #fff; }

  /* Validation pipeline */
  .pipeline { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
  .pipe-step { display: flex; align-items: center; gap: 0.35rem; padding: 0.35rem 0.7rem;
               border-radius: 6px; font-size: 0.75rem; font-weight: 600; }
  .pipe-pass { background: rgba(69,150,102,0.15); color: #ABEFC6; }
  .pipe-fail { background: rgba(255,38,42,0.12); color: #ff797a; }
  .pipe-skip { background: rgba(167,176,186,0.1); color: var(--muted); }
  .pipe-icon { font-size: 0.85rem; }

  /* Collapsible sections */
  .section-toggle { width: 100%; background: rgba(30,52,93,0.4); border: 1px solid var(--border);
                    border-radius: 8px; padding: 0.65rem 1rem; margin-bottom: 0.5rem;
                    color: var(--fg); font-family: 'Ubuntu', sans-serif; font-size: 0.8rem;
                    font-weight: 600; cursor: pointer; text-align: left;
                    display: flex; align-items: center; justify-content: space-between; }
  .section-toggle:hover { background: rgba(30,52,93,0.7); }
  .section-toggle .arrow { transition: transform 0.2s; font-size: 0.7rem; color: var(--muted); }
  .section-toggle.expanded .arrow { transform: rotate(90deg); }
  .section-content { display: none; margin-bottom: 1rem; }
  .section-content.open { display: block; }
  .code-block { background: #0a1628; border: 1px solid var(--border); border-radius: 8px;
                padding: 1rem; overflow-x: auto; margin-top: 0.5rem; }
  .code-block pre { font-family: 'Menlo', 'Consolas', monospace; font-size: 0.75rem;
                    color: var(--fg); white-space: pre-wrap; word-break: break-word;
                    line-height: 1.5; margin: 0; }
  .error-list { list-style: none; padding: 0; margin-top: 0.5rem; }
  .error-list li { background: rgba(255,38,42,0.08); border-left: 3px solid var(--red);
                   padding: 0.5rem 0.75rem; margin-bottom: 0.35rem; border-radius: 0 6px 6px 0;
                   font-size: 0.78rem; color: #ff797a; }

  /* Run selector tabs */
  .run-tabs { display: flex; gap: 0.3rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
  .run-tab { background: rgba(30,52,93,0.4); border: 1px solid var(--border);
             border-radius: 6px; padding: 0.35rem 0.75rem; font-size: 0.78rem;
             font-weight: 600; cursor: pointer; color: var(--muted);
             transition: all 0.15s; }
  .run-tab:hover { background: rgba(30,52,93,0.7); color: var(--fg); }
  .run-tab.active { background: var(--accent); color: var(--bg); border-color: var(--accent); }
  .run-tab .run-status { margin-left: 0.3rem; }
  .run-tab .run-pass { color: #ABEFC6; }
  .run-tab .run-fail { color: #ff797a; }
  .run-tab.active .run-pass,
  .run-tab.active .run-fail { color: var(--bg); }

  /* ---- Responsive ---- */
  @media (max-width: 800px) {
    body { padding: 1rem; }
    .charts { grid-template-columns: 1fr; }
    h1 { font-size: 1.2rem; }
    .pass-rate { font-size: 1.4rem; }
    .leaderboard, .chart-card, .results, .about { padding: 1.25rem; border-radius: 10px; }
    .modal { max-width: 100%; border-radius: 10px; }
    .metrics-bar { gap: 0.5rem; }
    .metric-chip { flex: 1 1 calc(50% - 0.5rem); min-width: 0; }
  }
  @media (max-width: 480px) {
    body { padding: 0.75rem; }
    .header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
    .subtitle { font-size: 0.72rem; margin-bottom: 1.5rem; }
    .leaderboard, .chart-card, .results, .about { padding: 1rem; }
    .lb-table th, .lb-table td { padding: 0.5rem 0.4rem; font-size: 0.78rem; }
    .tool-name { font-size: 0.85rem; }
    .pass-rate { font-size: 1.2rem; }
    .metric-chip { flex: 1 1 100%; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="nirmata-logo">
    {% include 'nirmata-logo.svg' %}
  </div>
</div>
<h1>Policy as Code Benchmark</h1>
<p class="subtitle">{{ agg.generated_at[:10] }} &middot; {{ agg.results | length }} tasks &middot; {{ agg.tool_stats | length }} tools &middot; Bare-minimum prompts, containerized isolation</p>

{# ---- About ---- #}
<div class="about">
  <p>This benchmark evaluates AI-powered tools on <strong>Kyverno Policy as Code</strong> tasks — converting legacy ClusterPolicies to the Kyverno 1.16+ format and generating new policies from natural-language descriptions. Each tool receives identical inputs and bare-minimum prompts inside containerized isolation, and its output is validated through schema checks, CEL expression analysis, and functional tests using the Kyverno CLI.</p>
  <p>Tools are ranked by <strong>pass rate only</strong> — the percentage of tasks that pass all validation layers. Speed and cost are reported as supplementary metrics. No composite scores or arbitrary weights.</p>
  {%- set max_runs = (agg.tool_stats.values() | map(attribute='n_runs_aggregated') | list) %}
  {%- set max_n = max_runs | max if max_runs else 1 %}
  {%- if max_n and max_n > 1 %}
  <p><strong>Methodology:</strong> Pass rates shown are the <strong>mean across {{ max_n }} independent runs per tool</strong> on the same dataset. LLM-backed benchmarks have inherent sampling variance — single-run scores are noisy. Reporting the mean (and per-policy pass-rate) gives a more representative measure of each tool&rsquo;s actual accuracy than a one-shot result.</p>
  {%- endif %}
  <p><a href="https://github.com/nirmata/policy-bench">View source, methodology &amp; full documentation on GitHub &rarr;</a></p>
</div>

{# ---- Leaderboard ---- #}
<div class="leaderboard">
  <h2>Leaderboard &mdash; ranked by pass rate</h2>
  <div class="table-scroll">
  <table class="lb-table">
    <tr>
      <th></th>
      <th>Tool</th>
      <th>Pass Rate</th>
      <th>Schema + CEL</th>
      <th>Functional</th>
      <th>Avg Time</th>
      <th>Avg Cost</th>
    </tr>
    {% for e in leaderboard %}
    <tr>
      <td><span class="rank rank-{{ e.rank if e.rank <= 3 else 'n' }}">{{ e.rank }}</span></td>
      <td class="tool-name">{{ e.tool }}</td>
      <td><span class="pass-rate {% if e.pass_rate >= 0.7 %}high{% elif e.pass_rate >= 0.4 %}mid{% else %}low{% endif %}">{{ "%.0f" | format(e.pass_rate * 100) }}%</span></td>
      <td class="metric">{{ e.schema_pass }}<span class="metric-label"> / {{ e.total }}</span></td>
      <td class="metric">{{ e.semantic_pass }}<span class="metric-label"> / {{ e.semantic_total }}</span></td>
      <td class="metric">{{ "%.1f" | format(e.avg_time) }}s</td>
      <td class="metric">${{ "%.4f" | format(e.avg_cost) if e.avg_cost else "-" }}</td>
    </tr>
    {% endfor %}
  </table>
  </div>
</div>

{# ---- Kyverno CLI Test Generation leaderboard ---- #}
{% if has_testgen is defined and has_testgen %}
<div class="leaderboard" style="margin-top:1.5rem;">
  <h2>Kyverno CLI Test Generation</h2>
  <p style="font-size:0.8rem;color:var(--muted);margin:0.25rem 0 0.75rem;">Composite pass = schema valid <em>and</em> <code>kyverno test</code> exits 0 <em>and</em> suite has both pass and fail cases. Coverage score = generated tuples / oracle tuples (capped at 1.0, not gated).</p>
  <div class="table-scroll">
  <table class="lb-table">
    <tr>
      <th>Tool</th>
      <th>Composite Pass</th>
      <th>Avg Coverage</th>
      <th>Has Pass+Fail</th>
      <th>Avg Time</th>
      <th>Avg Cost</th>
    </tr>
    {% for e in leaderboard_testgen %}
    <tr>
      <td class="tool-name">{{ e.tool }}</td>
      <td class="metric">{{ e.composite_pass }}<span class="metric-label"> / {{ e.total }}</span></td>
      <td class="metric">{{ "%.0f" | format(e.avg_coverage * 100) }}%</td>
      <td class="metric">{{ e.has_pass_and_fail }}<span class="metric-label"> / {{ e.total }}</span></td>
      <td class="metric">{{ "%.1f" | format(e.avg_time) if e.avg_time else "-" }}{{ "s" if e.avg_time else "" }}</td>
      <td class="metric">{{ "$%.4f" | format(e.avg_cost) if e.avg_cost else "-" }}</td>
    </tr>
    {% endfor %}
  </table>
  </div>
</div>
{% endif %}

{# ---- Charts ---- #}
<div class="charts">
  <div class="chart-card">
    <h2>Pass Rate Comparison</h2>
    <canvas id="passChart"></canvas>
  </div>
  <div class="chart-card">
    <h2>Accuracy vs Cost</h2>
    <canvas id="scatterChart"></canvas>
  </div>
</div>

{# ---- Per-task results ---- #}
<div class="results">
  <h2>Per-Task Results <span style="font-size:0.7rem;font-weight:400;color:var(--muted);text-transform:none;letter-spacing:0;">— click a cell for details</span></h2>
  <div class="table-scroll">
  <table class="res-table">
    <tr>
      <th>Policy</th>
      <th>Kind</th>
      {% for tool in agg.tool_stats.keys() | sort %}<th>{{ tool }}</th>{% endfor %}
    </tr>
    {% set ns = namespace(policies=[]) %}
    {% for r in agg.results %}
      {% if r.policy_id not in ns.policies %}
        {% set _ = ns.policies.append(r.policy_id) %}
      {% endif %}
    {% endfor %}
    {% for pid in ns.policies | sort %}
    <tr>
      <td>{{ pid }}</td>
      {% set first = agg.results | selectattr("policy_id", "equalto", pid) | first %}
      <td style="font-size:0.75rem; color:var(--muted);">{{ first.expected_output_kind | default("—") }}</td>
      {% for tool in agg.tool_stats.keys() | sort %}
        {% set match = agg.results | selectattr("policy_id", "equalto", pid) | selectattr("tool", "equalto", tool) | list %}
        {% if match %}
          {% set r = match[0] %}
          {% set n_runs = r.n_runs_aggregated | default(1) %}
          {% set rate = r.pass_rate | default(1.0 if r.success else 0.0) %}
          {% if n_runs > 1 and rate > 0 and rate < 1 %}
            {%- set n_pass = (rate * n_runs) | round | int -%}
            <td class="{% if r.success %}pass{% else %}fail{% endif %} clickable"
                data-tool="{{ tool }}" data-policy="{{ pid }}"
                onclick="openModal('{{ tool }}', '{{ pid }}')"
                title="passed {{ n_pass }} of {{ n_runs }} runs">{{ "PASS" if r.success else "FAIL" }} <span style="font-size:0.7rem; color:var(--muted);">({{ n_pass }}/{{ n_runs }})</span></td>
          {% else %}
            <td class="{% if r.success %}pass{% else %}fail{% endif %} clickable"
                data-tool="{{ tool }}" data-policy="{{ pid }}"
                onclick="openModal('{{ tool }}', '{{ pid }}')">{{ "PASS" if r.success else "FAIL" }}</td>
          {% endif %}
        {% else %}
          <td style="color:var(--muted);">—</td>
        {% endif %}
      {% endfor %}
    </tr>
    {% endfor %}
  </table>
  </div>
</div>

{# ---- Modal ---- #}
<div class="modal-overlay" id="modalOverlay" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <div class="modal-header">
      <h3 id="modalTitle">—</h3>
      <div style="display:flex;align-items:center;gap:0.75rem;">
        <span class="modal-badge" id="modalBadge">—</span>
        <button class="modal-close" onclick="closeModal()" aria-label="Close">&times;</button>
      </div>
    </div>
    <div class="modal-body">
      <div id="runTabsContainer"></div>
      <div class="metrics-bar" id="modalMetrics"></div>
      <div class="pipeline" id="modalPipeline"></div>
      <div id="modalSections"></div>
    </div>
  </div>
</div>

{# ---- Tool Summary Modal ---- #}
<div class="modal-overlay" id="toolModalOverlay" onclick="if(event.target===this)closeToolModal()">
  <div class="modal">
    <div class="modal-header">
      <h3 id="toolModalTitle">—</h3>
      <button class="modal-close" onclick="closeToolModal()" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body" id="toolModalBody"></div>
  </div>
</div>

<footer class="footer">
  <p>&copy; {{ agg.generated_at[:4] }} <a href="https://nirmata.com">Nirmata</a> &middot; <a href="https://github.com/nirmata/policy-bench">policy-bench</a></p>
</footer>

<script>
/* ---- Embed result data for modal lookups ---- */
const resultData = {{ agg.results | tojson }};
const toolSummaries = {{ agg.tool_summaries | default({}) | tojson }};

/* Build lookup: resultMap["tool::policy_id"] = result */
const resultMap = {};
resultData.forEach(r => { resultMap[r.tool + '::' + r.policy_id] = r; });

/* ---- Modal logic ---- */

/* Render metrics bar, pipeline, and collapsible sections for a single run.
   `run` is the per-run record; `parent` carries shared fields (prompt,
   description, etc.) that were stripped from sub-runs. */
function renderRunDetail(run, parent) {
  /* Merge: run fields take precedence, fall back to parent for shared fields */
  const r = Object.assign({}, parent, run);

  /* Metrics bar */
  const metrics = [];
  if (r.difficulty) metrics.push({ label: 'Difficulty', value: r.difficulty });
  if (r.task_type) metrics.push({ label: 'Task Type', value: r.task_type });
  if (r.expected_output_kind) metrics.push({ label: 'Expected Kind', value: r.expected_output_kind });
  if (r.conversion_time_seconds != null) metrics.push({ label: 'Time', value: r.conversion_time_seconds.toFixed(1) + 's' });
  if (r.cost_usd != null) metrics.push({ label: 'Cost', value: '$' + r.cost_usd.toFixed(4) });
  if (r.total_tokens != null) metrics.push({ label: 'Tokens', value: r.total_tokens.toLocaleString() });
  if (r.model) metrics.push({ label: 'Model', value: r.model });
  if (r.task_type === 'generate_test') {
    if (r.testgen_coverage_score != null) metrics.push({ label: 'Coverage', value: (r.testgen_coverage_score * 100).toFixed(0) + '%' });
    if (r.testgen_has_pass_and_fail != null) metrics.push({ label: 'Pass+Fail Cases', value: r.testgen_has_pass_and_fail ? 'yes' : 'no' });
    if (r.testgen_generated_tuples != null) metrics.push({ label: 'Generated Tuples', value: r.testgen_generated_tuples });
    if (r.testgen_oracle_tuples) metrics.push({ label: 'Oracle Tuples', value: r.testgen_oracle_tuples });
  }

  document.getElementById('modalMetrics').innerHTML = metrics.map(m =>
    '<div class="metric-chip"><span class="mc-label">' + esc(m.label) + '</span><span class="mc-value">' + esc(m.value) + '</span></div>'
  ).join('');

  /* Pipeline */
  const steps = [];
  if (r.schema_pass !== undefined) {
    steps.push({ label: 'Schema + CEL', status: r.schema_pass ? 'pass' : 'fail' });
  }
  if (r.lint_pass !== undefined) {
    const warns = (r.lint_warnings || []).length;
    steps.push({ label: 'Lint' + (warns ? ' (' + warns + ' warn)' : ''), status: r.lint_pass ? 'pass' : 'fail' });
  }
  if (r.semantic_skipped) {
    steps.push({ label: 'Functional', status: 'skip' });
  } else if (r.semantic_pass !== undefined) {
    steps.push({ label: 'Functional', status: r.semantic_pass ? 'pass' : 'fail' });
  }
  const icons = { pass: '\u2713', fail: '\u2717', skip: '\u2014' };
  document.getElementById('modalPipeline').innerHTML = steps.map(s =>
    '<span class="pipe-step pipe-' + s.status + '"><span class="pipe-icon">' + icons[s.status] + '</span> ' + esc(s.label) + '</span>'
  ).join('');

  /* Collapsible sections */
  const sections = [];

  if (r.description) {
    sections.push({ title: 'Task Description', content: '<div class="code-block"><pre>' + esc(r.description) + '</pre></div>' });
  }

  if (r.prompt) {
    sections.push({ title: 'Prompt', content: '<div class="code-block"><pre>' + esc(r.prompt) + '</pre></div>' });
  }

  if (r.input_snippet) {
    sections.push({ title: 'Input Policy', content: '<div class="code-block"><pre>' + esc(r.input_snippet) + '</pre></div>' });
  }

  if (r.output_yaml) {
    sections.push({ title: 'Generated Output', content: '<div class="code-block"><pre>' + esc(r.output_yaml) + '</pre></div>' });
  } else if (r.yaml_preview) {
    sections.push({ title: 'Generated Output', content: '<div class="code-block"><pre>' + esc(r.yaml_preview) + '</pre></div>' });
  }

  /* Errors */
  const allErrors = [].concat(
    r.error ? [r.error] : [],
    r.expected_kind_errors || [],
    r.schema_errors || [],
    r.semantic_errors || [],
  );
  if (allErrors.length) {
    let errHtml = '';
    if (r.error_summary) {
      errHtml += '<div style="background:rgba(69,150,102,0.08);border:1px solid var(--border);border-radius:8px;padding:0.8rem 1rem;margin-bottom:0.8rem;color:var(--fg);font-size:0.85rem;line-height:1.5;">'
              + esc(r.error_summary) + '</div>';
    }
    errHtml += '<details' + (r.error_summary ? '' : ' open') + '>'
            + '<summary style="font-size:0.8rem;color:var(--muted);cursor:pointer;margin-bottom:0.5rem;">'
            + 'Raw errors (' + allErrors.length + ')</summary>'
            + '<ul class="error-list">' + allErrors.map(e => '<li>' + esc(e) + '</li>').join('') + '</ul>'
            + '</details>';
    sections.push({
      title: 'Errors (' + allErrors.length + ')',
      content: errHtml,
    });
  }

  /* Lint warnings */
  if (r.lint_warnings && r.lint_warnings.length) {
    sections.push({
      title: 'Lint Warnings (' + r.lint_warnings.length + ')',
      content: '<ul class="error-list">' + r.lint_warnings.map(w => '<li style="border-left-color:var(--orange);color:var(--orange);">' + esc(w) + '</li>').join('') + '</ul>',
    });
  }

  if (r.raw_log) {
    sections.push({ title: 'Execution Log', content: '<div class="code-block"><pre>' + esc(r.raw_log) + '</pre></div>' });
  }

  document.getElementById('modalSections').innerHTML = sections.map((s, i) =>
    '<button class="section-toggle" onclick="toggleSection(this)">' + esc(s.title) + ' <span class="arrow">&#9654;</span></button>' +
    '<div class="section-content">' + s.content + '</div>'
  ).join('');

  /* Auto-expand first section */
  const firstToggle = document.querySelector('.section-toggle');
  if (firstToggle) toggleSection(firstToggle);
}

function selectRun(index) {
  const r = window._currentRecord;
  if (!r || !r.runs) return;

  /* Update active tab */
  document.querySelectorAll('.run-tab').forEach(function(tab, i) {
    tab.classList.toggle('active', i === index);
  });

  renderRunDetail(r.runs[index], r);
}

function openModal(tool, policyId) {
  const r = resultMap[tool + '::' + policyId];
  if (!r) return;

  /* Store for run switching */
  window._currentRecord = r;

  /* Title */
  document.getElementById('modalTitle').textContent = tool + ' / ' + policyId;

  /* Badge */
  const badge = document.getElementById('modalBadge');
  if (r.n_runs_aggregated > 1) {
    const nPass = r.pass_per_run.filter(Boolean).length;
    badge.textContent = (r.pass_rate * 100).toFixed(0) + '% (' + nPass + '/' + r.n_runs_aggregated + ' runs)';
    badge.className = 'modal-badge ' + (r.success ? 'pass-badge' : 'fail-badge');
  } else {
    badge.textContent = r.success ? 'PASS' : 'FAIL';
    badge.className = 'modal-badge ' + (r.success ? 'pass-badge' : 'fail-badge');
  }

  /* Run tabs — only when per-run detail records exist (clickable) */
  const tabsContainer = document.getElementById('runTabsContainer');
  if (r.runs && r.runs.length > 1) {
    let tabsHtml = '<div class="run-tabs">';
    r.runs.forEach(function(run, i) {
      const passed = r.pass_per_run[i];
      const statusIcon = passed ? '\u2713' : '\u2717';
      const statusClass = passed ? 'run-pass' : 'run-fail';
      tabsHtml += '<button class="run-tab' + (i === 0 ? ' active' : '') +
          '" onclick="selectRun(' + i + ')">' +
          'Run ' + (i + 1) +
          '<span class="run-status ' + statusClass + '">' + statusIcon + '</span>' +
          '</button>';
    });
    tabsHtml += '</div>';
    tabsContainer.innerHTML = tabsHtml;
  } else {
    tabsContainer.innerHTML = '';
  }

  /* Render detail for the first run (or the single record) */
  renderRunDetail(r.runs && r.runs.length > 1 ? r.runs[0] : r, r);

  document.getElementById('modalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeModal() {
  document.getElementById('modalOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

/* ---- Tool Summary Modal ---- */
function openToolModal(toolName) {
  document.getElementById('toolModalTitle').textContent = toolName + ' — Performance Summary';

  const stats = {{ agg.tool_stats | tojson }};
  const s = stats[toolName] || {};
  const summary = toolSummaries[toolName];

  // Collect per-task results for this tool
  const toolResults = resultData.filter(r => r.tool === toolName);

  // Classify by multi-run reliability using pass_per_run
  const robust = [];   // all runs pass (pass_rate === 1.0)
  const flaky = [];    // some runs pass (0 < pass_rate < 1)
  const alwaysFail = []; // no runs pass (pass_rate === 0)
  toolResults.forEach(function(r) {
    const ppr = r.pass_per_run;
    if (ppr && ppr.length > 1) {
      const nPass = ppr.filter(Boolean).length;
      if (nPass === ppr.length) robust.push(r);
      else if (nPass === 0) alwaysFail.push(r);
      else flaky.push(r);
    } else {
      // Single-run: binary pass/fail
      if (r.success) robust.push(r);
      else alwaysFail.push(r);
    }
  });

  const isMultiRun = (s.n_runs_aggregated || 1) > 1;

  let html = '';

  // Stats bar
  html += '<div class="metrics-bar">';
  html += '<div class="metric-chip"><span class="mc-label">Pass Rate</span><span class="mc-value">' + (s.pass_rate * 100).toFixed(0) + '%</span></div>';
  html += '<div class="metric-chip"><span class="mc-label">Schema+CEL</span><span class="mc-value">' + (s.schema_pass || 0) + ' / ' + (s.total || 0) + '</span></div>';
  html += '<div class="metric-chip"><span class="mc-label">Functional</span><span class="mc-value">' + (s.semantic_pass || 0) + ' / ' + (s.semantic_total || 0) + '</span></div>';
  html += '<div class="metric-chip"><span class="mc-label">Avg Time</span><span class="mc-value">' + (s.avg_time ? s.avg_time.toFixed(1) + 's' : 'N/A') + '</span></div>';
  html += '<div class="metric-chip"><span class="mc-label">Avg Cost</span><span class="mc-value">' + (s.avg_cost ? '$' + s.avg_cost.toFixed(4) : 'N/A') + '</span></div>';
  html += '</div>';

  // AI summary
  if (summary) {
    html += '<div style="background:rgba(69,150,102,0.08);border:1px solid var(--border);border-radius:8px;padding:1rem 1.2rem;margin:1rem 0;color:var(--fg);font-size:0.88rem;line-height:1.6;">'
         + esc(summary) + '</div>';
  }

  // Helper to render a policy list with optional per-run detail
  function policyList(items, showRunDetail) {
    return items.map(function(r) {
      let label = esc(r.policy_id);
      if (showRunDetail && r.pass_per_run && r.pass_per_run.length > 1) {
        var nPass = r.pass_per_run.filter(Boolean).length;
        label += ' <span style="color:var(--muted);font-size:0.72rem;">(' + nPass + '/' + r.pass_per_run.length + ')</span>';
      }
      return label;
    }).join(', ');
  }

  // Robust policies (all runs pass)
  if (robust.length) {
    var label = isMultiRun ? 'Robust — all ' + s.n_runs_aggregated + ' runs pass' : 'Passed';
    html += '<div style="margin-top:1rem;"><span style="font-size:0.8rem;font-weight:600;color:var(--green);">' + esc(label) + ' (' + robust.length + ')</span>';
    html += '<div style="font-size:0.8rem;color:var(--muted);margin-top:0.4rem;">'
         + policyList(robust, false) + '</div></div>';
  }

  // Flaky policies (some runs pass, some fail)
  if (flaky.length) {
    html += '<div style="margin-top:0.8rem;"><span style="font-size:0.8rem;font-weight:600;color:var(--orange);">Flaky — passes some runs (' + flaky.length + ')</span>';
    html += '<div style="font-size:0.8rem;color:var(--muted);margin-top:0.4rem;">'
         + policyList(flaky, true) + '</div></div>';
  }

  // Always-fail policies (no runs pass)
  if (alwaysFail.length) {
    var label = isMultiRun ? 'Always fails — 0/' + s.n_runs_aggregated + ' runs' : 'Failed';
    html += '<div style="margin-top:0.8rem;"><span style="font-size:0.8rem;font-weight:600;color:var(--red);">' + esc(label) + ' (' + alwaysFail.length + ')</span>';
    html += '<div style="font-size:0.8rem;color:var(--muted);margin-top:0.4rem;">'
         + policyList(alwaysFail, false) + '</div></div>';
  }

  document.getElementById('toolModalBody').innerHTML = html;
  document.getElementById('toolModalOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeToolModal() {
  document.getElementById('toolModalOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

function toggleSection(btn) {
  const content = btn.nextElementSibling;
  const isOpen = content.classList.contains('open');
  content.classList.toggle('open');
  btn.classList.toggle('expanded');
}

/* Escape HTML */
function esc(str) {
  if (str == null) return '';
  const d = document.createElement('div');
  d.textContent = String(str);
  return d.innerHTML;
}

/* Close on Escape key */
document.addEventListener('keydown', e => { if (e.key === 'Escape') { closeModal(); closeToolModal(); } });

/* ---- Charts ---- */
const chartColors = { nctl: '#459666', claude: '#FF262A', cursor: '#F3782C' };
const tools = {{ leaderboard | map(attribute='tool') | list | tojson }};
const passRates = {{ leaderboard | map(attribute='pass_rate') | list | tojson }}.map(x => x * 100);
const costs = {{ leaderboard | map(attribute='avg_cost') | list | tojson }}.map(x => x || 0);
const bgColors = tools.map(t => chartColors[t] || '#2E5596');

const gridColor = '#1e345d';
const tickColor = '#A7B0BA';
const scaleOpts = { grid: { color: gridColor }, ticks: { color: tickColor } };

// Pass rate bar chart
const passChart = new Chart(document.getElementById('passChart'), {
  type: 'bar',
  data: { labels: tools, datasets: [{ data: passRates, backgroundColor: bgColors, borderRadius: 8, barPercentage: 0.5 }] },
  options: {
    responsive: true,
    onClick: (evt, elements) => {
      if (elements.length) openToolModal(tools[elements[0].index]);
    },
    plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ctx.raw.toFixed(0) + '% — click for details' } } },
    scales: { y: { ...scaleOpts, beginAtZero: true, max: 100, ticks: { ...scaleOpts.ticks, callback: v => v + '%' } }, x: { ...scaleOpts, grid: { display: false } } }
  }
});

// Accuracy vs Cost scatter
new Chart(document.getElementById('scatterChart'), {
  type: 'scatter',
  data: {
    datasets: tools.map((t, i) => ({
      label: t,
      data: [{ x: costs[i] * 1000, y: passRates[i] }],
      backgroundColor: bgColors[i],
      pointRadius: 5,
      pointHoverRadius: 8,
    }))
  },
  options: {
    responsive: true,
    onClick: (evt, elements) => {
      if (elements.length) openToolModal(tools[elements[0].datasetIndex]);
    },
    plugins: {
      legend: { display: true, labels: { color: tickColor, usePointStyle: true, pointStyle: 'circle' } },
      tooltip: { callbacks: { label: ctx => ctx.dataset.label + ': ' + ctx.raw.y.toFixed(0) + '% pass, $' + (ctx.raw.x / 1000).toFixed(4) + '/task — click for details' } }
    },
    scales: {
      x: { ...scaleOpts, reverse: true, title: { display: true, text: 'Avg Cost per Task ($ ×1000) — lower is better →', color: tickColor }, grid: { color: gridColor } },
      y: { ...scaleOpts, title: { display: true, text: 'Pass Rate (%)', color: tickColor }, beginAtZero: true, max: 105, ticks: { ...scaleOpts.ticks, callback: v => v + '%' } }
    }
  }
});
</script>
</body>
