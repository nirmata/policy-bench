# Python
__pycache__/
*.py[cod]
.venv/
venv/

# OS
.DS_Store

# nctl conversion intermediate workspace (skill writes requirements + policy here, then copies to output/converted.yaml)
output/*-vpol/

# Generated by conversion and validation runs (keep repo clean)
output/*.yaml
output/**/*.yaml
results/*.json
results/*.log
results/policy-output-manifest-files/
!results/examples/*.json

# Report outputs (regenerated)
reports/output/

# Blind evaluation artifacts
blind-eval/anonymized/
blind-eval/.mapping.json
blind-eval/scores.json
blind-eval/revealed_scores.json

# Docker secrets (API keys for containerized benchmarks)
docker/secrets/
# nctl binary (downloaded by run-benchmark.sh)
docker/nctl

# Local cache (schemas, binaries — downloaded on first run)
.cache/

# Compiled Go validator binary (at repo root, not the cmd/ source dir)
/validate-policy

# Kyverno policies sync (see scripts/sync_kyverno_policies.py)
dataset/.cache/
dataset/imported/**
!dataset/imported/README.md
!dataset/imported/upstream-meta.json
